# Database Configuration
DATABASE_URL=postgresql://localhost:5432/swordle_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=swordle_dev
DB_USER=postgres
DB_PASSWORD=your_password_here

# Server Configuration
NODE_ENV=development
PORT=3000
WS_PORT=3001

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
SOLANA_PROGRAM_ID=Sw0rdLe111111111111111111111111111111111111
# Your wallet keypair (base64 encoded) - KEEP SECRET!
SOLANA_AUTHORITY_KEYPAIR=[]

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:19000,http://localhost:19001,http://localhost:19002

# Optional: Switchboard VRF (for randomness)
SWITCHBOARD_VRF_PUBKEY=

# Optional: Redis (for caching)
REDIS_URL=

# Optional: Sentry (for error tracking)
SENTRY_DSN=

# Admin
ADMIN_SECRET=change_this_to_process_days_manually
